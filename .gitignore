# Virtual environment
venv/

# Environment variables (API keys)
.env

# Python cache
__pycache__/
*.pyc
*.pyo

# Jupyter checkpoints
.ipynb_checkpoints/

# Data files (PDFs can be large)
# Keep ChromaDB out (too large, generated file)
data/chromadb/

# Keep raw data folder tracked but ignore chromadb
!data/
!data/*.pdf

# OS files
.DS_Store
Thumbs.db